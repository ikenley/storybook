{
  "name": "storybook-generator",
  "version": "1.0.0",
  "description": "syncronus task runner for creating AI-generated storybooks",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "ts-node src/cli.ts",
    "dev": "tsc --project tsconfig.json --watch & NODE_ENV=development nodemon dist",
    "prestart": "npm run build",
    "start": "nodemon",
    "test": "jest --detectOpenHandles",
    "test-coverage": "jest --coverage",
    "test-lambda": "ts-node --transpile-only ./src/local.ts",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "clean": "rm -rf dist build",
    "ts-node": "ts-node"
  },
  "author": "ikenley",
  "license": "SEE LICENSE IN LICENSE.txt",
  "repository": {
    "type": "git",
    "url": "https://github.com/ikenley/storybook"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1080.0",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/client-ses": "^3.1090.0",
    "@google/genai": "^2.10.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2"
  }
}
